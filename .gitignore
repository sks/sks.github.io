# Jekyll build output
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
vendor/
.bundle/

# ── Maintainer-only (keep local + backup/blog — never commit to origin/main) ──
scripts/
.local/
_staging/
AGENTS.md
docs/

# ── Terraform (secrets & state never commit) ──
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.*
terraform/terraform.tfvars
terraform/*.auto.tfvars
terraform/tfplan
terraform/plan.txt
terraform/crash.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json
# Commit terraform/.terraform.lock.hcl after tofu init
